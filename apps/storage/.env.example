# apps/storage — object-storage service. Dev-only file; prod reads real process.env / the deploy secret.

# --- service ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Shared secret for the internal-only ingress. Empty disables the auth gate (dev only); required in prod.
STORAGE_TOKEN=

# --- default backend (R2 main content bucket) — REQUIRED ---
S3_UPLOAD_ENDPOINT=
S3_UPLOAD_KEY=
S3_UPLOAD_SECRET=
S3_UPLOAD_BUCKET=
S3_UPLOAD_REGION=

# --- b2 backend (Backblaze model-files bucket) — optional ---
S3_UPLOAD_B2_ENDPOINT=
S3_UPLOAD_B2_ACCESS_KEY=
S3_UPLOAD_B2_SECRET_KEY=
S3_UPLOAD_B2_BUCKET=
S3_UPLOAD_B2_REGION=

# --- b2Image backend (Backblaze media-uploads / image bucket) — optional ---
S3_IMAGE_B2_ENDPOINT=
S3_IMAGE_B2_ACCESS_KEY=
S3_IMAGE_B2_SECRET_KEY=
S3_IMAGE_B2_BUCKET=
S3_IMAGE_B2_REGION=

# --- csam backend (CSAM evidence bucket) — optional ---
CSAM_UPLOAD_ENDPOINT=
CSAM_UPLOAD_KEY=
CSAM_UPLOAD_SECRET=
CSAM_BUCKET_NAME=
CSAM_UPLOAD_REGION=
