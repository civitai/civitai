# @civitai/auth-app (the login hub) environment.
#
# ALL of these are SERVER-ONLY (read via $env/dynamic/private). NONE need to be public:
# the login page is server-rendered, so the browser never reads env — there are no PUBLIC_*
# vars. Lines marked [secret] must never be exposed or committed (this file's real twin, .env,
# is gitignored). Lines marked [public-info] are non-sensitive but are still served by a server
# route (e.g. the JWKS endpoint), not shipped to the client.

# --- database ---
# Postgres connection used by Kysely. Same value as the main app's DATABASE_URL. [secret]
DATABASE_URL=postgres://user:pass@localhost:5432/civitai

# --- redis (cross-app session revocation: track on login, invalidate on logout/ban) ---
# Same instances as the main app, so a logout/ban here is seen everywhere. If unset, the hub
# still runs but tracking/revocation are skipped (sessions only expire by TTL). [secret]
REDIS_URL=redis://localhost:6379
REDIS_SYS_URL=redis://localhost:6379

# --- hub token signing (RS256 keypair — replaces NextAuth's single symmetric secret) ---
# Generate: openssl genpkey -algorithm RSA -pkcs8 -out priv.pem -pkeyopt rsa_keygen_bits:2048
#           openssl pkey -in priv.pem -pubout -out pub.pem
# (Multi-line PEM: in real .env use a quoted value with REAL newlines, not \n.)
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"  # signs tokens [secret]
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"      # served at JWKS for verify [public-info]
AUTH_JWT_KID=civitai-2026-06          # key id (labels the signing key for rotation) [public-info]
AUTH_JWT_ISSUER=http://localhost:5173 # hub canonical URL; the JWT `iss` claim. ~ old NEXTAUTH_URL [public-info]
AUTH_JWKS_URI=http://localhost:5173/api/auth/jwks  # the hub verifies its own cookies via this [public-info]

# (Session cookie name is hardcoded to the shared civitai-token / __Secure-civitai-token — it's a
# cross-app contract, not configurable.)

# Cookie Domain for the session cookie. EMPTY for localhost (host-only cookie — a value like
# .civitai.com would be REJECTED on localhost). In prod set to `.civitai.com` so the session is
# shared across every *.civitai.com subdomain. ~ old NEXTAUTH_COOKIE_DOMAIN. [public-info]
AUTH_COOKIE_DOMAIN=

# SvelteKit adapter-node only (prod): the public origin so url.origin (OAuth redirect URIs, email
# links) is correct behind a proxy. NOT needed for `vite dev`. e.g. https://auth.civitai.com
# ORIGIN=https://auth.civitai.com

# Symmetric secret, same value as the main app's NEXTAUTH_SECRET. Used here for (a) hashing
# email magic-link tokens and (b) decoding legacy NextAuth cookies during migration. [secret]
NEXTAUTH_SECRET=

# --- captcha (Cloudflare Turnstile, managed widget — same as the main app's email sign-in) ---
# Gate the email magic-link login behind a Turnstile challenge. Set BOTH halves (they're a pair).
# NOTE: env is per-deployment — the hub needs its own copy even though the main app already has
# the managed widget configured.
#   - SECRET  ([secret], server-side): verifies the token with Cloudflare. If unset, captcha is
#             silently DISABLED (email login runs with no challenge). Also bypassed in dev.
#   - SITEKEY ([public-info]): rendered in the browser widget so it can produce a token. Read
#             server-side and handed to the page via SSR, so it is NOT a PUBLIC_ var (the hub
#             drops the main app's NEXT_PUBLIC_ prefix).
CF_MANAGED_TURNSTILE_SECRET=
CF_MANAGED_TURNSTILE_SITEKEY=

# --- upstream OAuth providers (a provider's button shows only when both ID + SECRET are set) ---
# Same credentials as the main app. Register http://localhost:5173/login/<provider>/callback
# as an allowed redirect URI in each provider's console for local login. [secret]
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- email magic-link login (the email form shows only when these are set) ---
# SMTP config, same as the main app's EMAIL_*. [secret for USER/PASS]
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
