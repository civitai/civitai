# @civitai/auth-app (the login hub) environment.
#
# ALL of these are SERVER-ONLY (read via $env/dynamic/private). NONE need to be public:
# the login page is server-rendered, so the browser never reads env — there are no PUBLIC_*
# vars. Lines marked [secret] must never be exposed or committed (this file's real twin, .env,
# is gitignored). Lines marked [public-info] are non-sensitive but are still served by a server
# route (e.g. the JWKS endpoint), not shipped to the client.

# --- database ---
# Postgres connection used by Kysely. Same value as the main app's DATABASE_URL. [secret]
# For the identity smoke test, point this at a dev DB (the test only reads + writes the cache).
DATABASE_URL=postgres://user:pass@localhost:5432/civitai

# --- redis (cross-app session revocation: track on login, invalidate on logout/ban) ---
# Same instances as the main app, so a logout/ban here is seen everywhere. If unset, the hub
# still runs but tracking/revocation are skipped (sessions only expire by TTL). [secret]
REDIS_URL=redis://localhost:6379
REDIS_SYS_URL=redis://localhost:6379

# --- hub token signing (ES256 / EC P-256 keypair — replaces NextAuth's single symmetric secret) ---
# The signer hardcodes ES256, so these MUST be an EC P-256 (prime256v1) keypair — an RSA key throws
# at import (see packages/civitai-auth/src/sign.ts).
# Generate: openssl ecparam -genkey -name prime256v1 -noout -out priv.pem
#           openssl ec -in priv.pem -pubout -out pub.pem
# (Multi-line PEM: in real .env use a quoted value with REAL newlines, not \n.)
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"  # signs tokens [secret]
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"      # served at JWKS for verify [public-info]
AUTH_JWT_KID=civitai-2026-06          # key id (labels the signing key for rotation) [public-info]
AUTH_JWT_ISSUER=http://localhost:5173 # hub canonical URL; the JWT `iss` claim. ~ old NEXTAUTH_URL [public-info]
AUTH_JWKS_URI=http://localhost:5173/api/auth/jwks  # the hub verifies its own cookies via this [public-info]
# Optional token lifetime (has a default; only set to override). [public-info]
# AUTH_SESSION_MAX_AGE=2592000   # session token TTL in seconds (default 30d)

# (Session cookie name is hardcoded to civ-token / __Secure-civ-token — it's a cross-app contract,
# not configurable. DISTINCT from the legacy next-auth cookie (civitai-token / __Secure-civitai-token)
# so the two never collide. See SESSION_COOKIE_BASE in packages/civitai-auth/src/constants.ts.)

# Cookie Domain for the session cookie. EMPTY for localhost (host-only cookie — a value like
# .civitai.com would be REJECTED on localhost). In prod set to `.civitai.com` so the session is
# shared across every *.civitai.com subdomain. ~ old NEXTAUTH_COOKIE_DOMAIN. [public-info]
AUTH_COOKIE_DOMAIN=

# CORS allowlist: SAME-SITE *.civitai.com spokes allowed to call /api/auth/* directly from the browser
# (credentialed) via @civitai/auth's createAuthBrowserClient — instead of building their own proxies. Exact
# origins, comma-separated, e.g. https://moderator.civitai.com. localhost (any port) is auto-allowed in dev,
# so leave EMPTY for local dev. (Cross-site first-party LOGIN origins are NOT configured here — they live in
# the `TrustedSpokeDomain` DB table, which the hub's first-party OAuth client registry reads.) [public-info]
AUTH_CORS_ORIGINS=

# Subscription-tier resolution: the `product.metadata` KEY whose value names the membership tier, read while
# producing the rich session user. Must MATCH the main app's value. Unset → no tier is resolved (tier-gated
# features just won't see a tier). [public-info]
TIER_METADATA_KEY=

# Default post-login landing when a login COMPLETES with no returnUrl (the user came to the hub login
# directly). Sends them to the main app rather than the hub root. e.g. https://civitai.com in prod,
# http://localhost:3000 in dev. Unset → falls back to the hub-relative '/'. [public-info]
AUTH_DEFAULT_RETURN_URL=

# /admin allowlist: comma-separated numeric user ids allowed into the hub admin area (the
# TrustedSpokeDomain registry editor). e.g. 1,5. Fail-closed — unset/empty means NO admins (the area is
# locked), so set this on any deploy that needs admin access. [public-info]
AUTH_ADMIN_USER_IDS=

# --- SvelteKit adapter-node runtime (PRODUCTION only — `vite dev` ignores these) ---
# Behind the k8s ingress the Node process sees an internal address, so these tell it the real public
# origin + client IP. Distinct from AUTH_JWT_ISSUER above (that's the JWT `iss` claim / a crypto
# contract; this is a hosting/runtime concern) — though in prod both are https://auth.civitai.com.
#   - ORIGIN: the public URL. Drives url.origin → OAuth redirect_uri, email magic-link URLs, and
#     SvelteKit's CSRF origin check on the login/logout POSTs. Wrong/unset behind a proxy = those break.
#   - ADDRESS_HEADER + XFF_DEPTH: so event.getClientAddress() returns the real client IP (used by the
#     login/email RATE LIMITER and the Turnstile remoteip). Without it every request looks like it
#     comes from the ingress IP and the rate limits become effectively global. XFF_DEPTH = number of
#     trusted proxies in front of the app (set to your ingress chain depth; 1 is typical).
ORIGIN=https://auth.civitai.com
ADDRESS_HEADER=x-forwarded-for
XFF_DEPTH=1
# PORT is set by the Dockerfile (3000); override here only if needed. [public-info]

# Symmetric secret, same value as the main app's NEXTAUTH_SECRET. Used here for (a) hashing
# email magic-link tokens and (b) decoding legacy NextAuth cookies during migration. [secret]
NEXTAUTH_SECRET=

# Shared service secret for trusted server-to-server cache invalidation. A consuming app (e.g. the main
# app on a profile edit / ban) presents this to `POST /api/auth/identity` to bust/refresh a user's cached
# session. Must MATCH on the hub AND every app that invalidates. If unset here, invalidation is rejected
# (fail closed). Generate any high-entropy value, e.g. `openssl rand -hex 32`. [secret]
AUTH_INTERNAL_TOKEN=

# --- captcha (Cloudflare Turnstile, INVISIBLE widget — the frictionless key the main app uses for
#     its high-volume flows; ~99% solve vs the managed widget's interactive challenge) ---
# Gate the email magic-link login behind a Turnstile challenge. Set BOTH halves (they're a pair).
# NOTE: env is per-deployment — the hub needs its own copy. The sitekey's Cloudflare dashboard
# allow-listed hostnames MUST include the hub's host (auth.civitai.com) or the widget won't load.
#   - SECRET  ([secret], server-side): verifies the token with Cloudflare. If unset, captcha is
#             silently DISABLED (email login runs with no challenge). Also bypassed in dev.
#   - SITEKEY ([public-info]): rendered in the browser widget so it can produce a token. Read
#             server-side and handed to the page via SSR, so it is NOT a PUBLIC_ var (the hub
#             drops the main app's NEXT_PUBLIC_ prefix).
CF_INVISIBLE_TURNSTILE_SECRET=
CF_INVISIBLE_TURNSTILE_SITEKEY=

# --- upstream OAuth providers (a provider's button shows only when both ID + SECRET are set) ---
# Same credentials as the main app. Register http://localhost:5173/login/<provider>/callback
# as an allowed redirect URI in each provider's console for local login. [secret]
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- email magic-link login (the email form shows only when these are set) ---
# SMTP config, same as the main app's EMAIL_*. [secret for USER/PASS]
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- analytics (login-funnel tracking) ---
# Base URL of the shared ClickHouse TRACKER ingestion service — the SAME endpoint (and value) the main app's
# Tracker already POSTs to (its own CLICKHOUSE_TRACKER_URL), NOT a direct ClickHouse DB connection. The hub
# emits its own `LoginRedirect` action events here (POST {CLICKHOUSE_TRACKER_URL}/track/actions) when a login is
# shown with a `reason`, so login-funnel analytics survive the hub owning the login surface. The hub needs NO
# direct ClickHouse credentials (CLICKHOUSE_HOST/USERNAME/PASSWORD) — only this tracker URL. Unset → tracking is
# silently disabled (e.g. local dev). [public-info]
CLICKHOUSE_TRACKER_URL=
