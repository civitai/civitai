{
  "name": "@civitai/event-engine",
  "version": "1.9.8",
  "private": true,
  "description": "Kafka consumer that listens to database events from postgres and clickhouse and processes them (metrics, signals, CDC side effects).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "setup:digitalocean": "tsx scripts/setup-digitalocean.ts",
    "setup:clickhouse-rollup": "tsx scripts/setup-clickhouse-rollup-view.ts",
    "setup:topics": "tsx scripts/create-kafka-topics.ts",
    "reset:offsets": "tsx scripts/reset-consumer-offsets.ts",
    "redrive:outbox": "tsx scripts/redrive-outbox.ts",
    "teardown:pg-replication": "tsx scripts/teardown-pg-replication.ts",
    "consumer:test": "tsx -r tsconfig-paths/register src/index.ts",
    "port-forward": "tsx scripts/port-forward-k8s.ts",
    "generate-types": "tsx -r tsconfig-paths/register scripts/generate-types.ts",
    "test:spine": "tsx -r tsconfig-paths/register scripts/test-spine-transformation.ts"
  },
  "keywords": [
    "kafka",
    "debezium",
    "metrics",
    "event-driven"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@axiomhq/pino": "^1.3.1",
    "@clickhouse/client": "^1.12.1",
    "@types/lru-cache": "^7.10.9",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "kafkajs": "^2.2.4",
    "lru-cache": "^11.2.1",
    "meilisearch": "^0.53.0",
    "object-sizeof": "^2.6.5",
    "p-limit": "^7.1.1",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.3",
    "redis": "^5.8.3",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/p-limit": "^2.1.0",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
