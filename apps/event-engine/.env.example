# Postgres Configuration
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/civitai?schema=public&connection_limit=50

# Clickhouse Configuration
CLICKHOUSE_URL=https://USER:PASSWORD@your-clickhouse-host:8443
# CLICKHOUSE_METRIC_EVENTS_TABLE=entityMetricEvents

# Redis Configuration
REDIS_URL=redis://:PASSWORD@localhost:6379

# Kafka Configuration
# For local development with K8s NodePort: localhost:30092
# For Docker Compose: localhost:9092
# For K8s internal: metric-watcher-cluster-kafka-bootstrap.metric-watcher.svc:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=metric-event-watcher-local

# Debezium Configuration
# The consumer automatically configures Debezium on startup via DebeziumManager
# If Debezium Connect is not available at this URL, the consumer will log a warning and continue
# Default: http://localhost:8083 (used if not specified)
# For local development with K8s NodePort: http://localhost:30083
# For Docker Compose: http://localhost:8083
# For K8s internal: http://debezium-connect-cluster-connect-api:8083
DEBEZIUM_CONNECT_URL=http://localhost:8083
DEBEZIUM_SLOT=debezium_slot

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info
BATCH_INSERT_INTERVAL=30
INDEX_UPDATE_INTERVAL=300
INDEX_UPDATE_ENABLED=false
REDIS_CACHE_UPDATES_ENABLED=true
WORKER_POOL_SIZE=10
HEALTH_CHECK_PORT=3000

# Outbox Reconciliation Poller (backstop that drains Outbox rows the live CDC path missed)
# DEFAULT ON: requires the "Outbox".attempts column (packages/civitai-db-schema migration
# 20260720120000_add_outbox_table, now applied). Set OUTBOX_POLL_ENABLED=false to disable.
# OUTBOX_POLL_ENABLED=false     # opt-out; the poller runs by default
# OUTBOX_POLL_INTERVAL=300      # seconds between sweeps
# OUTBOX_POLL_GRACE=300        # seconds; only claim rows older than this (never races the CDC path)
# OUTBOX_POLL_BATCH_SIZE=100
# OUTBOX_MAX_ATTEMPTS=5        # park a row after this many failed attempts
AXIOM_TOKEN=
AXIOM_DATASET=civitai-event-watcher

# Cache Configuration
# QUERY_CACHE_MAX_SIZE=262144000        # 250MB in bytes
# QUERY_CACHE_SYNC_ENABLED=true         # Enable real-time sync across instances (default: true)
# QUERY_CACHE_BACKUP_KEY=query-cache:backup  # Redis key for cache backup (default: query-cache:backup)
# QUERY_CACHE_BACKUP_INTERVAL=300       # Backup interval in seconds
#                                        # Default: 300s (5min) if sync disabled, 1800s (30min) if sync enabled
# QUERY_CACHE_CHUNK_SIZE=500000         # Entries per chunk for backup/restore (default: 500000)
#                                        # Chunking prevents OOM on restore for large caches

# Signals Configuration (Optional)
# SIGNALS_API_URL=http://signals-service.internal
# SIGNALS_ENABLED=true

# Spine Orchestrator Configuration (Optional)
# SPINE_URL=https://spine.civitai.com
# SPINE_API_KEY=your-api-key-here
# SPINE_KAFKA_CALLBACK_URL=https://orchestrator-kafka.civitai.com/callback