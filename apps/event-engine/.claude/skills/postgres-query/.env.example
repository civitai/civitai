# PostgreSQL Connection URLs
# Use SSH tunnels for secure access to production databases

# Primary database (for writes, used with --writable flag)
# ssh -L 25060:civitai-db-host:25060 user@bastion
DATABASE_URL=postgresql://user:password@localhost:25060/database?schema=public

# Replica database (for reads, default)
# ssh -L 25070:replica-host:25060 user@bastion
DATABASE_REPLICA_URL=postgresql://user:password@localhost:25070/database?schema=public
