# Moderator app — auth env.
#
# This app is a *.civitai.com SPOKE: it shares the hub's `.civitai.com` session cookie, so it needs NO login
# UI, NO OAuth-bridge endpoints, NO AUTH_COOKIE_DOMAIN, and NO TrustedSpokeDomain row (same registrable domain
# → shared cookie + the owned-domain redirect backstop). It only verifies the session and gates on isModerator.

# The hub origin (token issuer). Used to verify the JWT `iss` and to build the login redirect.
AUTH_JWT_ISSUER=https://auth.civitai.com
# The hub's public keys, for LOCAL ES256 verification (no per-request hop for the signature check).
AUTH_JWKS_URI=https://auth.civitai.com/api/auth/jwks

# OPTIONAL — a shared cache redis (see @civitai/redis) lets the guard read the `session:data2` cache instead of
# calling the hub `/api/auth/identity` endpoint on every request. The gate works without it (it fails open to
# the identity fetch); wire it for performance + to inject real-time revocation. Leave unset for a simple POC.
# REDIS_URL=

# Local dev against a LOCAL hub: point the two vars at it, e.g.
#   AUTH_JWT_ISSUER=http://localhost:5173
#   AUTH_JWKS_URI=http://localhost:5173/api/auth/jwks
# (loopback hosts are auto-trusted by the hub in dev, so no seeding needed.)
