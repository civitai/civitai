# apps/notifications — runtime env (dev). Prod values come from the k8s SOPS secret
# (datapacket-talos: clusters/production/apps/civitai-notifications/secrets/). Copy to `.env` for local dev.
#
# This app owns the notification domain: a fan-out WORKER (poll loop over PendingNotification) plus an
# authed, internal-only producer API (POST /notifications). It reads BOTH the notif DB (queue + fan-out)
# and the main DB (userNotificationSettings opt-out filter) via @civitai/db.

# --- server ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Run the fan-out worker (the poll loop that drains PendingNotification → delivers notifications +
# signals) in THIS process. Default off. The API always runs; only flip this ON at worker-cutover, and
# never while the external notification-server worker is also running (two workers on one queue duplicate
# debounced notifications). See docs/plans/notifications-predeploy-checklist.md.
WORKER_ENABLED=false

# --- producer API auth (WEBHOOK_TOKEN-style shared secret on the internal-only ingress) ---
# The @civitai/notifications client sends this as `Authorization: Bearer <token>`. Empty disables the
# gate (dev only — NEVER leave unset in a networked environment). [secret]
NOTIFICATIONS_TOKEN=

# --- notification DB (queue + fan-out) — passed straight to @civitai/db's createClients as connection
#     strings. Omit the replica to run a single pool. Same pooler values as the monolith. [secret] ---
NOTIFICATION_DB_URL=postgres://user:pass@localhost:5432/notifications
NOTIFICATION_DB_REPLICA_URL=postgres://user:pass@localhost:5432/notifications
# Optional: dedicated pool size for the notif pools (falls back to DATABASE_POOL_MAX, then 20).
# NOTIFICATION_POOL_MAX=20

# --- main DB (userNotificationSettings opt-out read) — the replica URL is passed to createPool. [secret] ---
# Only the replica is read (the opt-out filter); DATABASE_URL is listed for parity with the monolith's env.
DATABASE_URL=postgres://user:pass@localhost:5432/civitai
DATABASE_REPLICA_URL=postgres://user:pass@localhost:5432/civitai

# --- redis (per-user unread counters) via @civitai/redis ---
# Cache redis (next-redis-cluster in prod → REDIS_CLUSTER=true). Holds `system:notification-counts:{userId}`.
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER=false
# @civitai/redis requires REDIS_URL and REDIS_SYS_URL together (both or neither). The app only uses the
# cache client, but the env contract still wants sys set. [secret]
REDIS_SYS_URL=redis://localhost:6379

# --- signals service (realtime unread-badge push per affected user) ---
SIGNALS_ENDPOINT=http://localhost:3001

# --- axiom logging via @civitai/axiom (all optional; stderr-only without a token) ---
AXIOM_TOKEN=
AXIOM_ORG_ID=
AXIOM_DATASTREAM=notifications
