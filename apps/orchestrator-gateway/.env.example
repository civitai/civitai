# apps/orchestrator-gateway — runtime env (dev). Prod values come from the k8s SOPS secret
# (datapacket-talos: clusters/production/apps/civitai-orchestrator-gateway/secrets/). Nothing here is shipped
# to a client — this is an API-only server. Copy to `.env` for local dev.

# --- server ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- auth (spoke-side local verification via @civitai/auth) ---
# The hub's JWKS endpoint (ES256 verify). Spokes verify tokens LOCALLY against this — no monolith hop.
AUTH_JWKS_URI=https://auth.civitai.com/api/auth/jwks
# The expected JWT `iss` claim (hub canonical URL). Also selects the __Secure- cookie prefix.
AUTH_JWT_ISSUER=https://auth.civitai.com
# Migration-window only: decode legacy next-auth cookies (same value as the main app's NEXTAUTH_SECRET).
# [secret] — omit to disable the legacy fallback.
NEXTAUTH_SECRET=

# --- database (Prisma via @civitai/db) — same pooler value as the main app's DATABASE_URL. [secret] ---
# Present-but-unused in P0 (the token-mint / feature reads land with the moved surface). Wired to prove the
# @civitai/db import + connection config only.
DATABASE_URL=postgres://user:pass@localhost:5432/civitai

# --- redis (cache + sys) via @civitai/redis ---
# Cache redis (next-redis-cluster in prod → REDIS_CLUSTER=true). fetchThroughCache lands in P1/P2.
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER=false
# System redis — GENERATION.TOKENS cache + generation-version gate + block budget counters. In prod this
# is discovered via REDIS_SYS_SENTINELS (group `sysmaster`); REDIS_SYS_URL still gates the factory. [secret]
REDIS_SYS_URL=redis://localhost:6379
# REDIS_SYS_SENTINELS=civitai-app-sysredis-sentinel-sentinel.civitai-app-sysredis.svc.cluster.local:26379
# REDIS_SYS_SENTINEL_NAME=sysmaster

# --- external orchestrator SDK (@civitai/client) ---
# Submit/get/cancel workflow on the EXTERNAL orchestrator. Present-but-unused in P0. [secret for the token]
ORCHESTRATOR_ENDPOINT=https://orchestration.civitai.com
ORCHESTRATOR_MODE=prod
ORCHESTRATOR_ACCESS_TOKEN=
