# Health check configuration for dev server readiness detection
# The {port} placeholder is replaced with the session's assigned port

HEALTH_CHECK_URL=http://localhost:{port}/api/health
HEALTH_CHECK_STATUS=200
HEALTH_CHECK_INTERVAL=1000
HEALTH_CHECK_TIMEOUT=120000

# RGB proxy — auto-start the civitai-dev.{red,green,blue} reverse proxy when the daemon boots
# Requires elevated shell on Windows (ports 80/443) or sudo on macOS/Linux
RGB_PROXY_ENABLED=false
RGB_PROXY_PATH=../rgb-proxy
